
# =============================================================================
# NanoClawbster Configuration
# =============================================================================

# --- Authentication (one of these is required) ---
ANTHROPIC_API_KEY=          # Your Anthropic API key — not needed if using Claude Code OAuth

# --- Discord (required) ---
DISCORD_BOT_TOKEN=          # Discord bot token from https://discord.com/developers/applications
ASSISTANT_NAME=Andy         # The @mention trigger word (default: Andy)

# --- Webhooks (optional — for Composio triggers like Gmail, GitHub) ---
WEBHOOK_PORT=3456           # Port for incoming webhook server
COMPOSIO_WEBHOOK_SECRET=    # Webhook signing secret from Composio Project Settings

# --- Container Tuning (optional) ---
CONTAINER_IMAGE=nanoclawbster-agent:latest   # Docker image name for agent containers
CONTAINER_TIMEOUT=1800000                    # Container timeout in ms (default: 30 min)
IDLE_TIMEOUT=1800000                         # Idle timeout before closing container stdin (default: 30 min)
MAX_CONCURRENT_CONTAINERS=5                  # Max parallel agent containers
